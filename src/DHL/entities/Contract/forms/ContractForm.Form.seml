        _name: AnnexStartDate
        value: AnnexStartDate
        useCustomLabel: false
        dataType: DATE
      - _type: TextField
        _name: ContractIdNumber
        value: ContractIdNumber
        useCustomLabel: false
        dataType: LONG_INTEGER
      - _type: TextField
        _name: Currency
        value: Currency
        useCustomLabel: false
        dataType: STRING
      - _type: TextField
        _name: ContractName
        value: ContractName
        useCustomLabel: false
        dataType: STRING
      - _type: TextField
        _name: StartDate
        value: StartDate
        useCustomLabel: false
        dataType: DATE
      - _type: TextField
        _name: EndDate
        value: EndDate
        useCustomLabel: false
        dataType: DATE
      - _type: TextField
        _name: SendDate
        value: SendDate
        useCustomLabel: false
        dataType: DATE
      - _type: TextField
        _name: SalesDepot
        value: SalesDepot
