        _name: PaymentTerms
        value: PaymentTerms
        useCustomLabel: false
        dataType: STRING
      - _type: CheckboxField
        _name: FlatFeeProducts
        value: FlatFeeProducts
        useCustomLabel: false
        dataType: BOOLEAN
      - _type: CheckboxField
        _name: FlatFeeOptions
        value: FlatFeeOptions
        useCustomLabel: false
        dataType: BOOLEAN
      - _type: CheckboxField
