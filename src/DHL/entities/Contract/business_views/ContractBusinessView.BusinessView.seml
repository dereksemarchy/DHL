_package: DHL.entities.Contract.business_views
_type: BusinessView
_name: ContractBusinessView
entity: DHL.entities.Contract.Contract
label: Contracts
rootLabel: Contracts
rootPluralLabel: Contracts
displayRootNodeAs: ICON_LABEL
rootBusinessViewEntity:
  _type: BusinessViewEntity
